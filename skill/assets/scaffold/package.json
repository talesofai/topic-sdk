{
  "name": "my-topic-page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": { "node": ">=18", "pnpm": ">=8" },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --open /dev-host/",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy:dev": "node scripts/deploy.mjs --target dev",
    "deploy:prod": "node scripts/deploy.mjs --target prod",
    "deploy:dry": "node scripts/deploy.mjs --dry-run"
  },
  "dependencies": {
    "@talesofai/topic-sdk": "git+https://github.com/talesofai/topic-sdk.git",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "ali-oss": "^6.17.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  }
}
